#!/bin/bash
# Update the system
yum update -y

# Install Apache (httpd)
yum install -y httpd

# Start and enable Apache
systemctl start httpd
systemctl enable httpd

# Get the host's IP address
HOST_IP=$(hostname -f)

# Get the current date
CURRENT_DATE=$(date '+%Y-%m-%d %H:%M:%S')

# Generate the HTML content
cat > /var/www/html/index.html <<EOF
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Landmark Technologies - DevOps Training Platform</title>
    <style>
        body {
            background-color: #1a1a2e;
            text-align: center;
            font-family: Arial, sans-serif;
            font-size: 18px;
            color: #ffffff;
        }
        h1, h2, p {
            margin: 20px 0;
        }
        h1 {
            color: #00d4ff;
            font-weight: bold;
            font-size: 36px;
        }
        h2 {
            color: #00d4ff;
            font-size: 22px;
        }
        .content {
            background-color: #16213e;
            margin: 40px auto;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 0 20px rgba(0,212,255,0.2);
            width: 80%;
            max-width: 700px;
        }
        .info {
            color: #a0a0a0;
            font-size: 16px;
        }
        .highlight {
            color: #00d4ff;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="content">
        <h1>Welcome to Landmark Technologies</h1>
        <h2>Online DevOps & AI Training Platform</h2>
        <p class="highlight">Host: $HOST_IP</p>
        <p class="info">Deployed: $CURRENT_DATE</p>
        <hr style="border-color: #00d4ff; opacity: 0.3;">
        <p>Landmark Technologies is an online DevOps and AI training platform. Our courses are crafted by industry experts to meet the dynamic expectations of the business and IT world.</p>
        <p><strong>Courses:</strong> DevOps Engineering | AI & Machine Learning | Cloud Computing | Kubernetes</p>
        <hr style="border-color: #00d4ff; opacity: 0.3;">
        <p class="info"><strong>Email:</strong> info@mylandmarktech.com</p>
        <p class="info"><strong>Phone:</strong> +1 437 215 2483</p>
        <p class="info"><strong>Location:</strong> Ontario, Canada</p>
    </div>
</body>
</html>
EOF

# Restart Apache to apply changes
systemctl restart httpd
